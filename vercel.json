{
  "rewrites": [
    { "source": "/metar-api/(.*)", "destination": "/api/metar-proxy" },
    { "source": "/metno-api/(.*)", "destination": "/api/metno-proxy" },
    { "source": "/wu-api/(.*)",    "destination": "/api/wu-proxy" },
    { "source": "/slack/(.*)",     "destination": "/api/slack-proxy" }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/*.js": {
      "runtime": "nodejs22.x"
    }
  }
}
